import { NextRequest, NextResponse } from "next/server";
import { prisma } from "@/lib/prisma";
import { updateProgressOnBOQGenerate } from "@/lib/project-progress";

/**
 * POST /api/projects/[id]/survey-complete
 * 
 * Called after QGIS field survey is completed and data is uploaded.
 * This triggers BOQ auto-generation from the GIS route data.
 * 
 * Flow: Job Assign → Survey (QGIS upload) → THIS ENDPOINT → BOQ Auto-Build → Continue Workflow
 */
export async function POST(
    request: NextRequest,
    { params }: { params: Promise<{ id: string }> }
) {
    try {
        const { id: projectId } = await params;
        const body = await request.json();

        // Find the project
        const project = await prisma.project.findUnique({
            where: { id: projectId },
            include: {
                gisRoutes: {
                    include: {
                        poles: true,
                        chambers: true,
                        closures: true,
                        cableSegments: true
                    }
                },
                job: true
            }
        });

        if (!project) {
            return NextResponse.json({ error: "Project not found" }, { status: 404 });
        }

        // Find GIS routes that need BOQ generation
        const routes = project.gisRoutes.filter(
            r => r.status !== "BOQ_GENERATED"
        );

        if (routes.length === 0) {
            return NextResponse.json({
                message: "No routes found needing BOQ generation",
                projectId
            });
        }

        const results = [];
        let totalBOQItems = 0;

        // Process each route
        for (const gisRoute of routes) {
            // Auto-calculate quantities
            const poleCount = gisRoute.poles.length;
            const chamberCount = gisRoute.chambers.length;
            const closureCount = gisRoute.closures.length;
            const cableSegmentCount = gisRoute.cableSegments.length;
            const totalCableLength = gisRoute.cableSegments.reduce(
                (sum, seg) => sum + (seg.length || 0), 0
            );

            // Fetch inventory items for unit rates
            const inventoryItems = await prisma.inventoryItem.findMany({
                where: {
                    OR: [
                        { code: { contains: "POLE", mode: "insensitive" } },
                        { code: { contains: "CBL", mode: "insensitive" } },
                        { name: { contains: "Pole", mode: "insensitive" } },
                        { name: { contains: "Fiber", mode: "insensitive" } },
                        { name: { contains: "Cable", mode: "insensitive" } },
                        { name: { contains: "Chamber", mode: "insensitive" } },
                        { name: { contains: "Closure", mode: "insensitive" } },
                        { name: { contains: "Splice", mode: "insensitive" } },
                    ]
                },
                take: 50
            });

            const findRate = (keywords: string[]): number => {
                const match = inventoryItems.find((item) =>
                    keywords.some((kw) =>
                        item.name?.toLowerCase().includes(kw.toLowerCase()) ||
                        item.code?.toLowerCase().includes(kw.toLowerCase())
                    )
                );
                return match?.unitPrice || 0;
            };

            // Build BOQ items
            const gisItems: Array<{
                itemCategory: string;
                itemCode: string;
                description: string;
                unit: string;
                quantity: number;
                unitRate: number;
                amount: number;
                sourceType: string;
                sourceReference: string;
            }> = [];

            if (poleCount > 0) {
                const rate = findRate(["pole", "wooden", "concrete"]);
                gisItems.push({
                    itemCategory: "POLE",
                    itemCode: "POLE-001",
                    description: "Fiber Optic Pole - Wooden/Concrete",
                    unit: "Nos",
                    quantity: poleCount,
                    unitRate: rate,
                    amount: poleCount * rate,
                    sourceType: "AUTO_CALCULATED",
                    sourceReference: `GIS survey: ${poleCount} poles`
                });
            }

            if (chamberCount > 0) {
                const rate = findRate(["chamber", "manhole"]);
                gisItems.push({
                    itemCategory: "CHAMBER",
                    itemCode: "CHMB-001",
                    description: "Fiber Optic Chamber / Manhole",
                    unit: "Nos",
                    quantity: chamberCount,
                    unitRate: rate,
                    amount: chamberCount * rate,
                    sourceType: "AUTO_CALCULATED",
                    sourceReference: `GIS survey: ${chamberCount} chambers`
                });
            }

            if (closureCount > 0) {
                const rate = findRate(["closure", "splice"]);
                gisItems.push({
                    itemCategory: "CLOSURE",
                    itemCode: "CLSR-001",
                    description: "Fiber Optic Splice Closure",
                    unit: "Nos",
                    quantity: closureCount,
                    unitRate: rate,
                    amount: closureCount * rate,
                    sourceType: "AUTO_CALCULATED",
                    sourceReference: `GIS survey: ${closureCount} closures`
                });
            }

            if (cableSegmentCount > 0) {
                const rate = findRate(["fiber", "cable"]);
                gisItems.push({
                    itemCategory: "CABLE",
                    itemCode: "CBL-001",
                    description: "Fiber Optic Cable",
                    unit: "Meters",
                    quantity: totalCableLength,
                    unitRate: rate,
                    amount: totalCableLength * rate,
                    sourceType: "AUTO_CALCULATED",
                    sourceReference: `GIS survey: ${cableSegmentCount} segments, ${totalCableLength.toFixed(1)}m`
                });
            }

            const totalEstimated = gisItems.reduce((sum, item) => sum + item.amount, 0);

            if (gisItems.length === 0) {
                results.push({ routeId: gisRoute.id, message: "Insufficient data for BOQ" });
                continue;
            }

            // Create GISGeneratedBOQ
            const boq = await prisma.gISGeneratedBOQ.create({
                data: {
                    routeId: gisRoute.id,
                    projectId,
                    status: "DRAFT",
                    totalEstimated,
                    notes: "Auto-generated from survey completion",
                    createdById: body.createdById || null,
                    items: {
                        create: gisItems
                    }
                },
                include: { items: true }
            });

            // Create ProjectBOQItems for the BOQ tab
            const projectBOQItems = gisItems.map((item, idx) => ({
                projectId,
                itemCode: `${item.itemCode}-${String(idx + 1).padStart(2, '0')}`,
                description: item.description,
                unit: item.unit,
                quantity: item.quantity,
                unitRate: item.unitRate,
                amount: item.amount,
                category: item.itemCategory,
                remarks: item.sourceReference
            }));

            if (projectBOQItems.length > 0) {
                // Delete old auto-generated items
                const existingItems = await prisma.projectBOQItem.findMany({
                    where: {
                        projectId,
                        remarks: { contains: "GIS survey" }
                    }
                });
                if (existingItems.length > 0) {
                    await prisma.projectBOQItem.deleteMany({
                        where: { id: { in: existingItems.map(i => i.id) } }
                    });
                }

                await prisma.projectBOQItem.createMany({ data: projectBOQItems });
            }

            // Update route status
            await prisma.gISRoute.update({
                where: { id: gisRoute.id },
                data: { status: "BOQ_GENERATED" }
            });

            totalBOQItems += gisItems.length;

            results.push({
                routeId: gisRoute.id,
                routeName: gisRoute.name,
                itemsGenerated: gisItems.length,
                totalEstimated,
                projectBOQItems: projectBOQItems.length
            });
        }

        // Update project budget
        const totalBOQ = results.reduce((sum, r) => sum + (r.totalEstimated || 0), 0);
        if (totalBOQ > 0) {
            await prisma.project.update({
                where: { id: projectId },
                data: { budget: totalBOQ }
            });
        }

        // Update job status if linked
        if (project.job) {
            await prisma.job.update({
                where: { id: project.job.id },
                data: { status: "SURVEY_COMPLETED" }
            });
        }

        // Update project progress after BOQ generation
        await updateProgressOnBOQGenerate(projectId);

        return NextResponse.json({
            message: `Survey complete. BOQ auto-generated: ${totalBOQItems} items across ${results.length} route(s).`,
            projectId,
            totalBOQItems,
            totalEstimated: totalBOQ,
            results,
            nextStep: "BOQ is now in DRAFT status. Review and approve to continue workflow."
        }, { status: 201 });
    } catch (error) {
        console.error("Error in survey-complete:", error);
        return NextResponse.json(
            { error: "Failed to process survey completion" },
            { status: 500 }
        );
    }
}