{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "System Status (1=Healthy, 0=Degraded)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "slts_db_status",
          "legendFormat": "Database Status",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Database Query Latency",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "slts_db_latency_seconds * 1000",
          "legendFormat": "Latency (ms)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Unresolved System Errors",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "slts_unresolved_errors_count",
          "legendFormat": "Unresolved",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Node.js Heap Used (MB)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "Heap Used",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Heap Trend",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "Used (MB)",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_total_bytes / 1024 / 1024",
          "legendFormat": "Total (MB)",
          "refId": "B"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Top Route Failures (24h)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "slts_route_failures_24h",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["sltserp", "monitoring"],
  "time": {
    "from": "now-1h",
    "to": "now"
