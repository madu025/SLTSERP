  itemType        String          @default("SERVICE") // SERVICE, MATERIAL, EQUIPMENT, MISC
  notes           String?
  createdAt       DateTime        @default(now())
  invoice         ProjectInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PaymentVoucher {
