  contractorId        String
  projectId           String?
  project             Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  evaluationMonth     String    // Format: "YYYY-MM"
  score               Float     @default(0) // 0-100%
  
  // Component Scores
