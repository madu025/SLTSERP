/**
 * PROJECT WORKFLOW AUDIT
 * Comprehensive audit of project workflow: stages, tasks, checklists, approvals
 */
const { PrismaClient } = require('@prisma/client');
const p = new PrismaClient();

const PROJECT_ID = 'cmqhuhahi00jzsiyk6bovq9ix'; // FSSD_SLTS_2026_001

async function main() {
  console.log('═══════════════════════════════════════════════════════════════');
  console.log('  PROJECT WORKFLOW AUDIT');
  console.log('═══════════════════════════════════════════════════════════════\n');

  // 1. Get project details
  const project = await p.project.findUnique({
    where: { id: PROJECT_ID },
    include: {
      projectType: true,
      projectWorkflowInstances: {
        include: {
          stageInstances: {
            orderBy: { sequence: 'asc' },
            include: {
              taskInstances: true,
              checklistInstances: true,
              approvalInstances: true,
              photoInstances: true,
            },
          },
        },
      },
    },
  });

  if (!project) {
    console.log('❌ Project not found!');
    return;
  }

  console.log(`📋 Project: ${project.projectCode} - ${project.name}`);
  console.log(`   Type: ${project.type}`);
  console.log(`   Status: ${project.status}`);
  console.log(`   Progress: ${project.progress}%`);
  console.log(`   Project Type ID: ${project.projectTypeId || 'N/A'}\n`);

  // 2. Check workflow instances
  const wfInstances = project.projectWorkflowInstances;
  console.log(`── Workflow Instances: ${wfInstances.length} ──────────────────────\n`);

  if (wfInstances.length === 0) {
    console.log('❌ NO WORKFLOW INSTANCES FOUND! Workflow was not initialized.\n');
    return;
  }

  let totalStages = 0;
  let totalTasks = 0;
  let completedStages = 0;
  let completedTasks = 0;
  let issues = [];

  for (const wf of wfInstances) {
    console.log(`  🔄 Workflow Instance: ${wf.id}`);
    console.log(`     Status: ${wf.status}`);
    console.log(`     Current Stage: ${wf.currentStageId || 'N/A'}`);
    console.log(`     Template ID: ${wf.templateId || 'N/A'}`);
    console.log(`     Stages: ${wf.stageInstances.length}\n`);

    totalStages += wf.stageInstances.length;

    for (const stage of wf.stageInstances) {
      const tasks = stage.taskInstances;
      const checklists = stage.checklistInstances;
      const approvals = stage.approvalInstances;
      const photos = stage.photoInstances;

      const completedTasksInStage = tasks.filter(t => t.status === 'COMPLETED').length;
      const allTasksDone = completedTasksInStage === tasks.length;

      if (stage.status === 'COMPLETED') completedStages++;
      completedTasks += completedTasksInStage;
      totalTasks += tasks.length;

      console.log(`    📌 Stage ${stage.sequence}: ${stage.name}`);
      console.log(`       Status: ${stage.status} ${stage.status === 'COMPLETED' ? '✅' : '⏳'}`);
      console.log(`       Tasks: ${tasks.length} (${completedTasksInStage} completed)`);
      console.log(`       Checklist Items: ${checklists.length} (${checklists.filter(c=>c.isChecked).length} checked)`);
      console.log(`       Approvals: ${approvals.length} (${approvals.filter(a=>a.status==='APPROVED').length} approved)`);
      console.log(`       Photos: ${photos.length}`);

      // --- AUDIT CHECKS ---
      
      // Check 1: Stage marked COMPLETED but tasks not all done
      if (stage.status === 'COMPLETED' && !allTasksDone) {
        issues.push(`⚠️ Stage "${stage.name}" marked COMPLETED but ${tasks.length - completedTasksInStage} tasks incomplete`);
      }

      // Check 2: All tasks done but stage not COMPLETED
      if (allTasksDone && tasks.length > 0 && stage.status !== 'COMPLETED') {
        issues.push(`⚠️ Stage "${stage.name}" all tasks done but stage status is ${stage.status} (should be COMPLETED)`);
      }

      // Check 3: Stage requires checklist but has none
      if (stage.reqChecklist && checklists.length === 0) {
        issues.push(`❌ Stage "${stage.name}" requires checklist but has 0 items`);
      }

      // Check 4: Stage requires approval but has none
      if (stage.reqApproval && approvals.length === 0) {
        issues.push(`❌ Stage "${stage.name}" requires approval but has 0 approval records`);
      }

      // Check 5: Mandatory checklist items not checked
      const mandatoryUnchecked = checklists.filter(c => c.isMandatory && !c.isChecked);
      if (mandatoryUnchecked.length > 0 && stage.status === 'COMPLETED') {
        issues.push(`❌ Stage "${stage.name}" COMPLETED but ${mandatoryUnchecked.length} mandatory checklist items unchecked`);
      }

      // Check 6: Approvals pending but stage completed
      const pendingApprovals = approvals.filter(a => a.status !== 'APPROVED');
      if (pendingApprovals.length > 0 && stage.status === 'COMPLETED') {
        issues.push(`❌ Stage "${stage.name}" COMPLETED but ${pendingApprovals.length} approvals pending`);
      }

      // Print task details
      for (const task of tasks) {
        const icon = task.status === 'COMPLETED' ? '✅' : task.status === 'IN_PROGRESS' ? '🔄' : '⬜';
        console.log(`       ${icon} Task: ${task.name} [${task.status}]`);
      }
      console.log('');
    }
  }

  // 3. Check workflow template
  console.log(`── Workflow Template Audit ──────────────────────────────────\n`);
  
  if (project.projectTypeId) {
    const templates = await p.workflowTemplate.findMany({
      where: { projectTypeId: project.projectTypeId, isActive: true },
      include: {
        stageTemplates: {
          orderBy: { sequence: 'asc' },
          include: {
            taskTemplates: true,
            checklistTemplates: true,
            approvalTemplates: true,
          },
        },
      },
    });

    console.log(`  Templates found: ${templates.length}`);
    for (const tmpl of templates) {
      console.log(`  📄 Template: ${tmpl.name} (ID: ${tmpl.id})`);
      console.log(`     Active: ${tmpl.isActive}`);
      console.log(`     Stage Templates: ${tmpl.stageTemplates.length}`);
      
      for (const st of tmpl.stageTemplates) {
        console.log(`     - Stage ${st.sequence}: ${st.name}`);
        console.log(`       Tasks: ${st.taskTemplates.length} | Checklist: ${st.checklistTemplates.length} | Approvals: ${st.approvalTemplates.length}`);
        console.log(`       reqApproval: ${st.reqApproval} | reqChecklist: ${st.reqChecklist} | reqPhotos: ${st.reqPhotos}`);
      }
    }
  } else {
    console.log('  ⚠️ No project type assigned to project');
  }

  // 4. Summary
  console.log('\n═══════════════════════════════════════════════════════════════');
  console.log('  AUDIT SUMMARY');
  console.log('═══════════════════════════════════════════════════════════════\n');
  
  console.log(`  Total Workflow Instances: ${wfInstances.length}`);
  console.log(`  Total Stages: ${totalStages} (${completedStages} completed)`);
  console.log(`  Total Tasks: ${totalTasks} (${completedTasks} completed)`);
  console.log(`  Issues Found: ${issues.length}\n`);

  if (issues.length > 0) {
    console.log('  ── ISSUES ──────────────────────────────────────────────\n');
    issues.forEach((issue, i) => console.log(`  ${i + 1}. ${issue}`));
    console.log('');
  } else {
    console.log('  ✅ NO ISSUES FOUND — Workflow is properly configured!\n');
  }

  // 5. Workflow completion percentage
  const stageCompletion = totalStages > 0 ? Math.round((completedStages / totalStages) * 100) : 0;
  const taskCompletion = totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0;
  
  console.log(`  Stage Completion: ${stageCompletion}%`);
  console.log(`  Task Completion: ${taskCompletion}%`);
  console.log(`  Project Progress Field: ${project.progress}%`);
  
  if (stageCompletion !== project.progress) {
    console.log(`  ⚠️ MISMATCH: Stage completion (${stageCompletion}%) ≠ Project progress (${project.progress}%)`);
  } else {
    console.log(`  ✅ Stage completion matches project progress`);
  }

  console.log('\n═══════════════════════════════════════════════════════════════\n');
}

main()
  .catch(e => {
    console.error('Audit failed:', e);
  })
  .finally(() => p.$disconnect());